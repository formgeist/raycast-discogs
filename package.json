{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "discogs",
  "title": "Discogs",
  "description": "Browse and search your Discogs record collection",
  "icon": "extension-icon.png",
  "author": "formgeist",
  "categories": [
    "Media"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "search-collection",
      "title": "Search My Collection",
      "description": "Browse and search your Discogs record collection",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "username",
      "title": "Discogs Username",
      "description": "Your Discogs username",
      "type": "textfield",
      "required": true
    },
    {
      "name": "token",
      "title": "Personal Access Token",
      "description": "Generate one at discogs.com/settings/developers",
      "type": "password",
      "required": true
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.11",
    "@raycast/utils": "^2.2.3"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/react": "^19.2.14",
    "eslint": "^10.2.0",
    "typescript": "^6.0.2"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  }
}
